---
const items = [
  'Residential Moves',
  'Corporate Relocation',
  'Fine Art Transport',
  'Long Distance',
  'Same-Day Service',
  'Storage Solutions',
  'Packing & Crating',
  'International',
];
---

<div class="marquee-wrap">
  <div class="marquee-track">
    {[...items, ...items].map(item => (
      <div class="marquee-item">
        <span class="dot"></span>
        {item}
      </div>
    ))}
  </div>
</div>

<style>
  .marquee-wrap {
    padding: 32px 0;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    background: var(--bg-surface);
  }

  .marquee-track {
    display: flex;
    animation: marquee 30s linear infinite;
    width: max-content;
  }

  .marquee-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 0 36px;
    white-space: nowrap;
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-3);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-1);
    flex-shrink: 0;
    opacity: 0.5;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
