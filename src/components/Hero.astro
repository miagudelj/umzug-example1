---
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <img
      src="https://images.unsplash.com/photo-1600585152220-90363fe7e115?w=1920&q=80"
      alt="Moving boxes in a bright room"
      loading="eager"
    />
    <div class="hero-overlay"></div>
  </div>
  <div class="wrap">
    <div class="hero-content">
      <p class="hero-eyebrow">Ihr Zügelunternehmen mit Herz</p>
      <h1>
        <span class="line">Your Move,</span>
        <span class="line"><span class="serif italic">Perfected.</span></span>
      </h1>
      <p class="hero-p">
        We don't just move boxes. We orchestrate transitions — with white-glove precision,
        radical transparency, and an obsession for keeping your world intact.
      </p>
      <div class="hero-btns">
        <a href="#quote" class="btn btn-fill-white">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Offerte anfragen
        </a>
        <a href="#services" class="btn btn-ghost-white">
          Unsere Services
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(26, 26, 46, 0.82) 0%,
      rgba(26, 26, 46, 0.6) 50%,
      rgba(26, 26, 46, 0.45) 100%
    );
  }

  .hero .wrap {
    position: relative;
    z-index: 2;
  }

  .hero-content {
    max-width: 720px;
    padding: 120px 0 80px;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--accent-2);
    margin-bottom: 24px;
    opacity: 0;
    transform: translateY(20px);
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 900;
    letter-spacing: -2px;
    margin-bottom: 24px;
    color: #fff;
    opacity: 0;
    transform: translateY(40px);
  }

  .hero h1 .serif {
    color: var(--accent-2);
  }

  .line { display: block; }
  .line:nth-child(2) { margin-left: clamp(10px, 3vw, 60px); }

  .hero-p {
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: var(--text-on-dark-2);
    max-width: 500px;
    line-height: 1.8;
    margin-bottom: 40px;
    opacity: 0;
    transform: translateY(30px);
  }

  .hero-btns {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(30px);
  }

  @media (max-width: 768px) {
    .hero-content { padding: 100px 0 60px; }

    .hero-btns {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-btns .btn {
      justify-content: center;
      text-align: center;
    }

    .hero-overlay {
      background: linear-gradient(
        180deg,
        rgba(26, 26, 46, 0.7) 0%,
        rgba(26, 26, 46, 0.85) 100%
      );
    }
  }
</style>
